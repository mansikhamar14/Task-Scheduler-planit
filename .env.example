# PlanIt Environment Variables
# Copy this file to .env.local and fill in the actual values

# MongoDB Connection String (MongoDB Atlas)
MONGODB_URI=mongodb+srv://username:password@cluster-name.mongodb.net/planit?retryWrites=true&w=majority

# NextAuth Configuration
# Generate a secret: `openssl rand -base64 32`
NEXTAUTH_SECRET=your-secret-key-here-change-this-in-production
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (get from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# JWT Secret for credentials-based auth
JWT_SECRET=your-jwt-secret-key-change-in-production

# Google Generative AI (for Gemini chatbot)
NEXT_PUBLIC_GEMINI_API_KEY=your-gemini-api-key
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key

# Email configuration (for password reset, notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@planit.app
